{
  "name": "elysia_backend",
  "version": "1.0.50",
  "type": "module",
  "scripts": {
    "menu": "bun run ./support/script/menu.ts",
    "dev": "bun run script_generate && bun run --watch ./app/cluster.ts",
    "fix": "bunx --bun @biomejs/biome check --write .",
    "generate": "bun run script_generate && bun run prisma_generate",
    "script_generate": "bun ./support/script/index.ts",
    "prisma_generate": "bun --bun run prisma generate"
  },
  "dependencies": {
    "@elysiajs/eden": "latest",
    "@elysiajs/openapi": "1.4.14",
    "@elysiajs/static": "1.4.7",
    "@prisma/adapter-mariadb": "7.4.2",
    "@prisma/client": "7.4.2",
    "elysia": "latest",
    "prismabox": "1.1.26"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.4",
    "bun-types": "latest",
    "prisma": "7.4.2"
  },
  "module": "./index.js"
}
